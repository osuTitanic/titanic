{{ extends "/layout.jet" }}
{{ import "/components/editor.jet" }}

{{ block head() }}
<title>Create a Topic - Forum</title>
<link rel="stylesheet" href="{{ cachedUrl("/css/forums.css") }}">
{{ end }}

{{ block body() }}
<style>
    .header-text { margin: 10px 5px 10px 5px }
</style>
<h1 class="header-text">
    <a href="/forum" style="color:#5a5399">Index</a> »
    {{ range _, parent := .Parents }}
        <a href="/forum/{{ parent.Id }}">{{ parent.Name }}</a> »
    {{ end }}
    <a href="/forum/{{ .Forum.Id }}">{{ .Forum.Name }}</a>
</h1>
<form action="/forum/{{ .Forum.Id }}/create" method="post" style="padding: 0 5px;">
    {{ yield editor() .Editor }}
    <input type="hidden" name="csrf_token" value="{{ .CSRFToken }}">
</form>
<br>
{* Ctrl+Enter -> Submit forum topic *}
<script>
    $(document).on("keydown", function(event) {
        var keyCode = event.which || event.keyCode;
        if (event.ctrlKey && keyCode === 13) {
            var submitButton = $('.post-buttons input[type="submit"]')[0];
            if (submitButton) {
                submitButton.click();
                submitButton.disabled = true;
            }
        }
    });
</script>
{{ end }}
