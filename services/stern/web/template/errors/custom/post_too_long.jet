{{ extends "/layout.jet" }}

{{ block head() }}
<title>Post too long - Titanic!</title>
<link rel="stylesheet" href="{{ cachedUrl("/css/error.css") }}">
{{ end }}

{{ block body() }}
<img src="{{ cachedUrl("/images/art/ffffff.png") }}" alt="Error Image">
<div class="description">
    <h1>Your post is too long!</h1>
    Please limit your post to 15000 characters or less.
</div>
{{ end }}
