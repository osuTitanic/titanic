{{ extends "/layout.jet" }}

{{ block head() }}
<title>Post Locked - Titanic!</title>
<link rel="stylesheet" href="{{ cachedUrl("/css/error.css") }}">
{{ end }}

{{ block body() }}
<img src="{{ cachedUrl("/images/art/ffffff.png") }}" alt="Error Image">
<div class="description">
    <h1>The post you are trying to edit is locked!</h1>
</div>
{{ end }}
