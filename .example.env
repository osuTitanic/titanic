## General
COMPOSE_PROJECT_NAME=titanic
TZ=UTC
DATA_PATH=.data

# The base domain name of your server
# Example: `titanic.sh`, `example.com`, `localhost`
DOMAIN_NAME=localhost

# Database configuration
POSTGRES_PASSWORD=examplePassword
POSTGRES_USER=bancho
POSTGRES_DATABASE=
POSTGRES_PORT=5432
POSTGRES_POOL_ENABLED=True
POSTGRES_POOL_SIZE=10
POSTGRES_POOL_SIZE_OVERFLOW=30
POSTGRES_POOL_PRE_PING=True
POSTGRES_POOL_RECYCLE=900
POSTGRES_POOL_TIMEOUT=15

# Redis configuration
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASS=

# S3 Storage configuration (optional)
S3_BASEURL=https://s3.us-gov-east-1.amazonaws.com
S3_SECRET_KEY=your_secret
S3_ACCESS_KEY=your_key
S3_BUCKET=osutitanic
S3_REGION=

# If disabled, the data gets stored locally
# Buckets will be created automatically when enabled
S3_ENABLED=False

# Cloudflare cache purge configuration (optional)
CLOUDFLARE_PURGE_ENABLED=False
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_PURGE_OSZ_URLS=[]

# This icon will be visible inside the menu (optional)
MENUICON_IMAGE=
MENUICON_URL=

# A list of background image urls that will be seen in the menu
SEASONAL_BACKGROUNDS=["http://swooo.sh/HNSrM2yw/oMJ57bAqKe.jpg", "http://swooo.sh/HNSrM2yw/qZ4B5AB6iX.jpg"]

# Discord webhook url for logging (optional)
OFFICER_WEBHOOK_URL=

# Event webhook urls (Updates for beatmaps, forums, etc.)
ANNOUNCE_EVENTS_WEBHOOK_URL=
BEATMAP_EVENTS_WEBHOOK_URL=
FORUM_EVENTS_WEBHOOK_URL=

# Image proxy baseurl for bbcode, using go-camo (optional)
# https://github.com/cactus/go-camo
IMAGE_PROXY_BASEURL=

# Domains that are eligible to bypass the image proxy
VALID_IMAGE_SERVICES=["ibb.co", "i.ibb.co", "puu.sh", "s01.flagcounter.com"]

## Email configuration (optional)
# Supported providers: "sendgrid", "mailgun", "smtp"
EMAIL_PROVIDER=

# Your email address
EMAIL_SENDER=

# SMTP configuration
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=True
SMTP_SKIP_TLS_VERIFY=False

# Sendgrid configuration
SENDGRID_API_KEY=

# Mailgun configuration
MAILGUN_API_KEY=

## Score server configuration

# Amount of scores that will be sent for rankings
SCORE_RESPONSE_LIMIT=50

# Maximum amount of beatmap favourites a user can have
BEATMAP_FAVOURITES_LIMIT=100

# Disable/Enable score submission for relax & autopilot
ALLOW_RELAX=False

# This will award pp and rscore for approved/loved maps
APPROVED_MAP_REWARDS=False

# You can change this, depending on how many cpu cores you have
WEB_HOST=localhost
WEB_PORT=80
WEB_WORKERS=2

# Allow direct beatmap downloads without an authenticated website session
ALLOW_UNAUTHENTICATED_DIRECT=True

# Enable or disable beatmap submission
BEATMAP_SUBMISSION_ENABLED=False

# Used to freeze rank graph updates, useful for pp recalculations
FROZEN_RANK_UPDATES=False

# Similar to the previous config, this will disable all ppv1 recalculation tasks
FROZEN_PPV1_UPDATES=False

## Bancho configuration

# Enable/disable irc-based connections
IRC_ENABLED=True
OSU_IRC_ENABLED=True

# Ports used by bancho services
BANCHO_TCP_PORTS=[13380, 13381, 13382, 13383]
BANCHO_HTTP_PORT=5000
BANCHO_WS_PORT=5001
BANCHO_IRC_PORT=6667
BANCHO_IRC_PORT_SSL=6697

# SSL configuration (optional)
BANCHO_SSL_KEYFILE=
BANCHO_SSL_CERTFILE=

# Verify file for SSL connections (optional)
BANCHO_SSL_VERIFY_FILE=

# You can change this, depending on how many threads you have
BANCHO_WORKERS=10

# Time in seconds to let clients know when they can reconnect after a restart
BANCHO_RESTART_TIME=20

# This will enable maintenance mode. Only admins can connect in this state.
# You can also enable this using the !system maintenance command
BANCHO_MAINTENANCE=False

# Will reject any login attempt with a client above the specified version (optional)
BANCHO_CLIENT_CUTOFF=

# The server will skip multiaccounting checks if set to True
ALLOW_MULTIACCOUNTING=False

# These channels will be automatically joined when logging in
AUTOJOIN_CHANNELS=["#osu", "#announce"]

# Used for bancho_connect.php endpoint (optional)
# Make sure this ip is not proxied in any way
PUBLIC_BANCHO_IP=127.0.0.1

# This will verify the hash of the client, if set to False
# You will need to edit the "releases" table to make it actually usable
# Admins will automatically bypass this check by default
DISABLE_CLIENT_VERIFICATION=True
MULTIPLAYER_MAX_SLOTS=8

## Website configuration

# You can change this, depending on how many cpu cores you have
FRONTEND_HOST=localhost
FRONTEND_PORT=8080
FRONTEND_WORKERS=2

# A secret for validating session tokens
# Set this to something unique
FRONTEND_SECRET_KEY=somethingrandom

# This is the expiry time for authentication tokens
FRONTEND_TOKEN_EXPIRY=3600
FRONTEND_REFRESH_EXPIRY=2592000

# Enable this if you are using an ssl certificate
ENABLE_SSL=False
ALLOW_INSECURE_COOKIES=

# reCAPTCHA key configuration
RECAPTCHA_SECRET_KEY=
RECAPTCHA_SITE_KEY=

# IDs of users whom appear to have everyone added as a friend (comma-separated)
SUPER_FRIENDLY_USERS=[1]

# Cutoff timestamp for showing "since the beginning" join dates
BEGINNING_ENDED_AT=2023-12-31T06:00:00

# Wiki configuration
WIKI_REPOSITORY_OWNER=osuTitanic
WIKI_REPOSITORY_NAME=wiki
WIKI_REPOSITORY_BRANCH=main
WIKI_REPOSITORY_PATH=wiki
WIKI_DEFAULT_LANGUAGE=en
REMOVE_SCORES_ON_RANKED=True

## API configuration

# You can change this, depending on how many cpu cores you have
API_HOST=localhost
API_PORT=8000
API_WORKERS=2

# Ratelimiting configuration
API_RATELIMIT_ENABLED=True
API_RATELIMIT_WINDOW=60
API_RATELIMIT_REGULAR=400
API_RATELIMIT_AUTHENTICATED=800

# Ko-Fi donations (optional)
KOFI_VERIFICATION_TOKEN=

## Discord bot configuration (optional)

ENABLE_DISCORD_BOT=False
DISCORD_BOT_PREFIX=!
DISCORD_BOT_TOKEN=
DISCORD_STAFF_ROLE_ID=
DISCORD_BAT_ROLE_ID=

# Used for importing data from the official servers (optional)
OSU_CLIENT_ID=
OSU_CLIENT_SECRET=

# Used for redirecting chat messages from discord to #osu (optional)
CHAT_WEBHOOK_URL=
CHAT_CHANNEL_ID=
CHAT_WEBHOOK_CHANNELS=["#osu"]

## Release stream updates (optional)

RELEASE_UPDATES_ENABLED=False
RELEASE_UPDATE_LOCATION=release
RELEASE_UPDATE_NOTIFY_WEBHOOK=

## Debugging options

DEBUG=False
RELOAD=False

## Custom URL overrides (optional)

OSU_BASEURL=
API_BASEURL=
STATIC_BASEURL=
EVENTS_WEBSOCKET=
LOUNGE_BACKEND=
